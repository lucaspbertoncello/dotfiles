{
  // typography
  "agent_buffer_font_size": 18.0,
  "agent_ui_font_size": 20.0,
  "lsp": {
    "yaml-language-server": {
      "settings": {
        "yaml": {
          "validate": false,
          "schemaStore": {
            "enable": false,
          },
        },
      },
    },
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
      },
      "enable_lsp_tasks": true,
    },
  },
  "cli_default_open_behavior": "existing_window",
  "ui_font_family": ".ZedSans",
  "ui_font_size": 20.0,
  "ui_font_weight": 100.0,
  "buffer_font_family": "MonoLisa",
  "buffer_font_size": 16.0,
  "buffer_font_weight": 300.0,
  "buffer_line_height": {
    "custom": 2.0,
  },

  // theme
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Vesper",
  },
  "icon_theme": {
    "mode": "light",
    "light": "Colored Zed Icons Theme Dark",
    "dark": "Colored Zed Icons Theme Dark",
  },

  // editor behavior
  "formatter": "prettier",
  "languages": {
    "TypeScript": {
      "formatter": "prettier",
      "code_actions_on_format": {
        "source.organizeImports": true,
        "source.addMissingImports.ts": true,
      },
    },
    "TSX": {
      "formatter": "prettier",
      "code_actions_on_format": {
        "source.organizeImports": true,
        "source.addMissingImports.ts": true,
      },
    },
    "JavaScript": {
      "formatter": "prettier",
      "code_actions_on_format": {
        "source.organizeImports": true,
        "source.addMissingImports.ts": true,
      },
    },
    "JSX": {
      "formatter": "prettier",
      "code_actions_on_format": {
        "source.organizeImports": true,
        "source.addMissingImports.ts": true,
      },
    },
    "JSON": { "formatter": "prettier" },
    "CSS": { "formatter": "prettier" },
  },
  "autosave": "off",
  "format_on_save": "on",
  "ensure_final_newline_on_save": true,
  "remove_trailing_whitespace_on_save": true,
  "soft_wrap": "editor_width",
  "preferred_line_length": 100,
  "wrap_guides": [110, 130],
  "tab_size": 2,
  "mouse_wheel_zoom": false,

  // editor visuals
  "current_line_highlight": "gutter",
  "cursor_blink": false,
  "cursor_shape": "block",
  "show_whitespaces": "selection",
  "unnecessary_code_fade": 0.4,
  "colorize_brackets": true,
  "linked_edits": true,
  "semantic_tokens": "combined",

  "minimap": {
    "show": "never",
  },

  "scrollbar": {
    "axes": {
      "vertical": false,
    },
    "git_diff": false,
  },

  "indent_guides": {
    "enabled": true,
    "line_width": 1,
    "active_line_width": 1,
    "coloring": "fixed",
  },

  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },

  "tabs": {
    "file_icons": false,
    "git_status": true,
    "show_close_button": "hover",
    "show_diagnostics": "errors",
  },

  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },

  "project_panel": {
    "dock": "left",
    "default_width": 220,
    "auto_fold_dirs": false,
  },
  "outline_panel": {
    "dock": "right",
  },
  "notification_panel": {
    "dock": "right",
  },
  "chat_panel": {
    "dock": "right",
  },

  "git": {
    "enabled": true,
    "git_gutter": "tracked_files",
    "inline_blame": {
      "padding": 2,
      "enabled": true,
      "delay_ms": 800,
    },
  },

  "gutter": {
    "line_numbers": true,
    "runnables": false,
    "folds": true,
  },

  "terminal": {
    "font_family": "Google Sans Code Monospaced",
    "font_weight": 400.0,
    "font_size": 14.0,
    "line_height": {
      "custom": 1.5,
    },
    "shell": "system",
    "dock": "bottom",
    "default_height": 280,
  },

  "auto_signature_help": false,
  "show_signature_help_after_edits": false,

  "inlay_hints": {
    "enabled": false,
    "show_type_hints": false,
    "show_parameter_hints": false,
    "show_other_hints": false,
  },

  "show_completions_on_input": true,
  "show_completion_documentation": true,
  "show_edit_predictions": false,

  "base_keymap": "VSCode",
  "session": {
    "trust_all_worktrees": true,
  },

  "file_types": {
    "tailwindcss": ["*.css"],
  },

  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
  },
}
