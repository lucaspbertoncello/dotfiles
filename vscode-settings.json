{
  // ─── Tema e Aparência Geral ──────────────────────────────────────────────────
  "workbench.colorTheme": "Vesper",
  "workbench.colorCustomizations": {
    "editor.foldBackground": "#00000000",
  },
  "window.zoomLevel": 0.8,
  "window.menuBarVisibility": "compact",

  // ─── Workbench / Layout ──────────────────────────────────────────────────────
  "workbench.editor.labelFormat": "short",
  "workbench.editor.empty.hint": "hidden",
  "workbench.editor.untitled.hint": "hidden",
  "workbench.startupEditor": "newUntitledFile",

  // ─── Editor / Tipografia ─────────────────────────────────────────────────────
  "editor.fontFamily": "Google Sans Code Proportional",
  "editor.fontSize": 14,
  "editor.lineHeight": 32,
  "editor.fontLigatures": true,

  // ─── Editor / Comportamento Visual ──────────────────────────────────────────
  "editor.rulers": [110, 130],
  "editor.renderLineHighlight": "gutter",
  "editor.scrollbar.vertical": "hidden",
  "editor.minimap.enabled": false,
  "editor.wordWrap": "on",
  "editor.smoothScrolling": true,
  "editor.cursorBlinking": "phase",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.bracketPairColorization.enabled": true,
  "editor.semanticHighlighting.enabled": true,
  "editor.linkedEditing": true,

  // ─── Editor / Indentação e Formatação ───────────────────────────────────────
  "editor.tabSize": 2,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
  },
  "editor.parameterHints.enabled": false,

  // ─── Editor / Sugestões e IntelliSense ──────────────────────────────────────
  "editor.inlineSuggest.enabled": true,

  // ─── Formatadores por Linguagem ──────────────────────────────────────────────
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[css]": {
    "editor.suggest.insertMode": "replace",
  },
  "[prisma]": {
    "editor.defaultFormatter": "Prisma.prisma",
    "editor.formatOnSave": true,
  },

  // ─── Terminal Integrado ──────────────────────────────────────────────────────
  "terminal.integrated.fontSize": 12,
  "terminal.integrated.lineHeight": 1.5,
  "terminal.integrated.fontLigatures.enabled": true,

  // ─── Explorer ────────────────────────────────────────────────────────────────
  "explorer.compactFolders": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,

  // ─── Git ─────────────────────────────────────────────────────────────────────
  "git.confirmSync": false,
  "git.suggestSmartCommit": false,

  // ─── GitLens ─────────────────────────────────────────────────────────────────
  "gitlens.defaultDateFormat": null,
  "gitlens.hovers.currentLine.over": "line",
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",

  // ─── TypeScript / JavaScript ─────────────────────────────────────────────────
  "typescript.updateImportsOnFileMove.enabled": "never",
  "javascript.updateImportsOnFileMove.enabled": "never",

  // ─── Emmet ───────────────────────────────────────────────────────────────────
  "emmet.syntaxProfiles": {
    "javascript": "jsx",
  },
  "emmet.includeLanguages": {
    "javascript": "javascriptreact",
  },

  // ─── Associações de Arquivos ─────────────────────────────────────────────────
  "files.associations": {
    "*.css": "tailwindcss",
  },

  // ─── Material Icon Theme ─────────────────────────────────────────────────────
  "material-icon-theme.activeIconPack": "nest",
  "material-icon-theme.folders.associations": {
    "domain": "core",
    "infra": "app",
    "main": "public",
    "presentation": "connection",
    "cryptography": "secure",
    "entities": "class",
    "repositories": "mappings",
    "protocols": "resource",
    "useCases": "components",
    "subcomponents": "components",
    "adapters": "connection",
    "factories": "container",
    "globals": "global",
    "ui": "views",
    "features": "components",
    "http": "core",
    "core": "class",
    "dto": "resource",
    "modals": "components",
    "stores": "context",
    "sections": "components",
    "sls": "serverless",
    "middy": "middleware",
  },
  "material-icon-theme.files.associations": {
    "ormconfig.json": "database",
    "tsconfig.json": "tune",
    ".lintstagedrc.json": "tune",
  },

  // ─── Symbols (ícones alternativos) ───────────────────────────────────────────
  "symbols.hidesExplorerArrows": true,
  "symbols.files.associations": {
    "*.module.ts": "none",
    "*.controller.ts": "none",
    "*.service.ts": "none",
  },

  // ─── GitHub Copilot ──────────────────────────────────────────────────────────
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.enable": {
    "*": false,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
  },

  // ─── Claude Code ─────────────────────────────────────────────────────────────
  "claudeCode.selectedModel": "default",
  "claudeCode.useTerminal": true,
  "claudeCode.useCtrlEnterToSend": true,
  "claudeCode.preferredLocation": "panel",

  // ─── Chat (Copilot Chat / Claude Chat) ───────────────────────────────────────
  "chat.editor.fontSize": 13,
  "chat.editor.lineHeight": 26,
  "chat.editor.wordWrap": "on",

  // ─── Cursor (AI editor) ──────────────────────────────────────────────────────
  "cursor.cpp.disabledLanguages": ["plaintext", "markdown", "scminput"],

  // ─── Extensões Diversas ──────────────────────────────────────────────────────
  "extensions.ignoreRecommendations": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "less.format.preserveNewLines": false,
  "security.workspace.trust.untrustedFiles": "open",
  "liveServer.settings.donotShowInfoMsg": true,
  "errorLens.fontStyleItalic": true,
  "codesnap.roundedCorners": true,
  "codesnap.showLineNumbers": false,
  "codesnap.containerPadding": "1em",
  "code-runner.executorMap": {
    "typescript": "ts-node",
  },
}
